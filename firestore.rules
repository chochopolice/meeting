rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == "vgW29wAqLeTATkfgq6iGj0agpBT2";
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reservations/{reservationId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "reserved"
        && request.resource.data.hours >= 1
        && request.resource.data.hours <= 24;

      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow update: if isAdmin()
        || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.status == "cancelled"
        );

      allow delete: if isAdmin();
    }

    match /room_slots/{slotId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.roomId is string
        && request.resource.data.date is string
        && request.resource.data.hour >= 0
        && request.resource.data.hour <= 23
        && request.resource.data.reservationId is string
        && request.resource.data.status == "reserved";

      allow update: if isAdmin();

      allow delete: if isAdmin()
        || (
          isSignedIn()
          && resource.data.reservationId is string
          && exists(/databases/$(database)/documents/reservations/$(resource.data.reservationId))
          && get(/databases/$(database)/documents/reservations/$(resource.data.reservationId)).data.userId == request.auth.uid
        );
    }

    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
