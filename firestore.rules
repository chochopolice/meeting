rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.uid in [
        "YOUR_ADMIN_UID"
      ];
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reservations/{reservationId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /room_slots/{slotId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /admin_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
